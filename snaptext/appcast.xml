            <sparkle:version>6</sparkle:version>
            <sparkle:shortVersionString>1.5</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <description><![CDATA[
                <h3>What's New in SnapText 1.5</h3>
